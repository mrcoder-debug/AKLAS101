# Postgres connection
# Local dev: matches docker-compose credentials
# Production (Neon): use the POOLED connection string as DATABASE_URL
DATABASE_URL="postgresql://lms:lms@localhost:5432/lms?schema=public"

# Neon only: direct (non-pooled) connection used by Prisma migrations.
# Local dev: same as DATABASE_URL (or omit — only required on Neon/serverless).
DIRECT_URL="postgresql://lms:lms@localhost:5432/lms?schema=public"

# Auth.js v5
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"
# Used by NextAuth for absolute URLs in production
AUTH_URL="http://localhost:3000"
# Trust the configured URL in dev/preview
AUTH_TRUST_HOST="true"

# AI features (Anthropic)
ANTHROPIC_API_KEY="sk-ant-..."

# Email (Resend) — required for invite emails
RESEND_API_KEY="re_..."
FROM_EMAIL="noreply@yourdomain.com"
# Full public URL of the app — used in invite email links
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Comma-separated list of origins permitted to be embedded as simulators.
SIMULATOR_FRAME_SRC_ALLOWLIST="https://wokwi.com,https://www.tinkercad.com"

# Login throttling (requests per window, per IP+email)
AUTH_LOGIN_RATE_LIMIT="10"
AUTH_LOGIN_RATE_WINDOW_MS="60000"
